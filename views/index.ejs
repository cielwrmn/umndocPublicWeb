    <!-- Javascript Animations -->
    <script>
        let i = 0;
        let txt = "UMN Documentation..."
        var speed = 50;

        function typeWriter(){
            if (i < txt.length){
                document.getElementById("homeTxt").textContent += txt.charAt(i);
                i++;
                setTimeout(typeWriter, speed);
            } else {
                console.log("animation finished");
            }
        }

        document.addEventListener("DOMContentLoaded", function () {
            homeTxt.textContent = "";
            typeWriter();
        });
    </script>
    
    
